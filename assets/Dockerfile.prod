# === 生产优化建议 ===

# 1. 使用多阶段构建减少镜像大小
# 2. 使用非root用户运行容器
# 3. 设置资源限制
#    docker run --memory="1g" --cpus="2" tg-signer-enhanced
#
# 4. 配置持久化存储
#    docker volume create tg-signer-data
#    docker run -v tg-signer-data:/app/.signer tg-signer-enhanced
#
# 5. 启用日志轮转
#    docker run -v ./logs:/app/.signer/logs tg-signer-enhanced
#
# 6. 安全加固
#    docker run --read-only --tmpfs /tmp tg-signer-enhanced
#
# 7. 监控集成
#    docker stats tg-signer-enhanced
#    docker logs -f tg-signer-enhanced


# === 构建和运行命令 ===

# 构建镜像
# docker build -f Dockerfile.prod -t tg-signer-enhanced:latest .

# 运行容器
# docker run -d \
#   --name tg-signer \
#   -p 8080:8080 \
#   -v ./data:/app/.signer \
#   -e TG_API_ID=your_api_id \
#   -e TG_API_HASH=your_api_hash \
#   -e TG_SIGNER_GUI_AUTHCODE=your_password \
#   tg-signer-enhanced:latest

# 查看日志
# docker logs -f tg-signer

# 进入容器调试
# docker exec -it tg-signer sh

# 停止容器
# docker stop tg-signer